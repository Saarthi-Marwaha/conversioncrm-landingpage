# ConversionCRM — environment template. Copy to .env.local and fill in.
# Never commit real secrets; .env.local is gitignored.

# ── Supabase (Settings → API) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=

# ── Resend (email delivery) ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@mail.yourdomain.com
RESEND_FROM_NAME=ConversionCRM

# ── Razorpay (subscriptions & billing) ──
# API keys: Dashboard → Account & Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Webhook secret: Dashboard → Settings → Webhooks
# Endpoint: https://<your-domain>/api/webhooks/razorpay
RAZORPAY_WEBHOOK_SECRET=
# Monthly plan ids: Dashboard → Subscriptions → Plans (plan_xxx)
#   Basic $20/20k · Pro $99/100k · Premium $399/200k
RAZORPAY_PLAN_BASIC=
RAZORPAY_PLAN_PRO=
RAZORPAY_PLAN_PREMIUM=
RAZORPAY_CURRENCY=USD

# ── Sales / contact ──
NEXT_PUBLIC_SALES_EMAIL=ceo.conversioncrm@gmail.com

# ── Cron security (openssl rand -hex 32) ──
CRON_SECRET=

# ── App ──
NEXT_PUBLIC_APP_URL=https://conversioncrm.co
NEXTAUTH_SECRET=

# Keep false — no bypass past login + the pricing gate.
BYPASS_AUTH=false
