# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
# Project URL — found in Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publishable (anon) key — safe for browser/widget (RLS-protected)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# Service role key — server-side only, NEVER expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# Resend (email delivery)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=ConversionCRM

# ─────────────────────────────────────────────
# Lemon Squeezy (subscriptions & billing)
# ─────────────────────────────────────────────
LEMONSQUEEZY_API_KEY=your_api_key
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_signing_secret
LEMONSQUEEZY_VARIANT_STARTER=12345
LEMONSQUEEZY_VARIANT_PRO=67890

# ─────────────────────────────────────────────
# Cron security
# ─────────────────────────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
